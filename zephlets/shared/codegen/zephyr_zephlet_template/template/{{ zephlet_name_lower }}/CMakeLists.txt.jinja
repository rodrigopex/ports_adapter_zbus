if(CONFIG_{{ zephlet_name_upper }}_ZEPHLET)
    # Register proto for nanopb
    set_property(GLOBAL APPEND PROPERTY PROTO_FILES_LIST
        "${ZEPHYR_{{ zephlet_name_upper }}_ZEPHLET_MODULE_DIR}/{{ zephlet_name_lower }}_zephlet.proto")

    # Auto-generate zephlet infrastructure to build directory
    zephyr_zephlet_generate({{ zephlet_name_lower }}_zephlet
        "${ZEPHYR_{{ zephlet_name_upper }}_ZEPHLET_MODULE_DIR}/{{ zephlet_name_lower }}_zephlet.proto")

    # Expose build directory globally for zephlet headers
    zephyr_include_directories("${CMAKE_CURRENT_BINARY_DIR}")

    # Interface library with include paths
    zephyr_interface_library_named({{ zephlet_name_lower }}_zephlet)
    target_include_directories({{ zephlet_name_lower }}_zephlet INTERFACE
        ${ZEPHYR_{{ zephlet_name_upper }}_ZEPHLET_MODULE_DIR}           # Source (for _impl.c)
        "${CMAKE_CURRENT_BINARY_DIR}"               # Build (for .h/.c/.priv.h)
        "${CMAKE_BINARY_DIR}/zephlets"              # Build parent (for .pb.h)
    )

    # Add sources: generated (build) + implementation (source)
    zephyr_library()
    zephyr_library_sources(
        ${{ "{" }}{{ zephlet_name_lower }}_zephlet_GENERATED_C{{ "}" }}
        ${ZEPHYR_{{ zephlet_name_upper }}_ZEPHLET_MODULE_DIR}/{{ zephlet_name_lower }}_zephlet_impl.c
    )

    add_dependencies(${ZEPHYR_CURRENT_LIBRARY} {{ zephlet_name_lower }}_zephlet_codegen)
    zephyr_library_link_libraries({{ zephlet_name_lower }}_zephlet)
endif()
