if(CONFIG_{{ service_name_upper }}_SERVICE)
    # Register proto for nanopb
    set_property(GLOBAL APPEND PROPERTY PROTO_FILES_LIST
        "${ZEPHYR_{{ service_name_upper }}_SERVICE_MODULE_DIR}/{{ service_name_lower }}_service.proto")

    # Auto-generate service infrastructure to build directory
    zephyr_service_generate({{ service_name_lower }}_service
        "${ZEPHYR_{{ service_name_upper }}_SERVICE_MODULE_DIR}/{{ service_name_lower }}_service.proto")

    # Expose build directory globally for service headers
    zephyr_include_directories("${CMAKE_CURRENT_BINARY_DIR}")

    # Interface library with include paths
    zephyr_interface_library_named({{ service_name_lower }}_service)
    target_include_directories({{ service_name_lower }}_service INTERFACE
        ${ZEPHYR_{{ service_name_upper }}_SERVICE_MODULE_DIR}           # Source (for _impl.c)
        "${CMAKE_CURRENT_BINARY_DIR}"               # Build (for .h/.c/.priv.h)
        "${CMAKE_BINARY_DIR}/modules/services"      # Build parent (for .pb.h)
    )

    # Add sources: generated (build) + implementation (source)
    zephyr_library()
    zephyr_library_sources(
        ${{ "{" }}{{ service_name_lower }}_service_GENERATED_C{{ "}" }}
        ${ZEPHYR_{{ service_name_upper }}_SERVICE_MODULE_DIR}/{{ service_name_lower }}_service_impl.c
    )

    add_dependencies(${ZEPHYR_CURRENT_LIBRARY} {{ service_name_lower }}_service_codegen)
    zephyr_library_link_libraries({{ service_name_lower }}_service)
endif()
